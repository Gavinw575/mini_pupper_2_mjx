<mujoco model="mini_pupper_2">

  <!-- ============================================================ -->
  <!-- COMPILER                                                      -->
  <!-- ============================================================ -->
  <compiler angle="radian" meshdir="meshes" autolimits="true" balanceinertia="true"/>

  <!-- ============================================================ -->
  <!-- OPTIONS                                                       -->
  <!-- MJX-compatible: pyramidal friction, Newton solver            -->
  <!-- timestep=0.004 matches Colab physics_dt                      -->
  <!-- ============================================================ -->
  <option timestep="0.004" iterations="2" ls_iterations="6"
          solver="Newton" cone="pyramidal" jacobian="dense"/>

  <!-- ============================================================ -->
  <!-- CUSTOM: MJX contact options                                   -->
  <!-- Required by pupperv3_mjx utils.set_mjx_custom_options()      -->
  <!-- Values overwritten at runtime by Colab config                 -->
  <!-- ============================================================ -->
  <custom>
    <numeric name="max_contact_points" data="8"/>
    <numeric name="max_geom_pairs" data="8"/>
  </custom>

  <!-- ============================================================ -->
  <!-- ASSETS                                                        -->
  <!-- ============================================================ -->
  <asset>
    <!-- Structural leg meshes -->
    <mesh name="base_link"  file="base_link.stl"/>
    <mesh name="lf1"        file="lf1.stl"/>
    <mesh name="lf2"        file="lf2.stl"/>
    <mesh name="lf3"        file="lf3.stl"/>
    <mesh name="rf1"        file="rf1.stl"/>
    <mesh name="rf2"        file="rf2.stl"/>
    <mesh name="rf3"        file="rf3.stl"/>
    <mesh name="lb1"        file="lb1.stl"/>
    <mesh name="lb2"        file="lb2.stl"/>
    <mesh name="lb3"        file="lb3.stl"/>
    <mesh name="rb1"        file="rb1.stl"/>
    <mesh name="rb2"        file="rb2.stl"/>
    <mesh name="rb3"        file="rb3.stl"/>
    <mesh name="lffoot"     file="lffoot.stl"/>
    <mesh name="rffoot"     file="rffoot.stl"/>
    <mesh name="lbfoot"     file="lbfoot.stl"/>
    <mesh name="rbfoot"     file="rbfoot.stl"/>
    <!-- Visual-only body meshes (plates/shells removed - purely decorative, -->
    <!-- cause visual artifacts due to URDF fixed-joint offset complexity)   -->

    <!-- Visual-only body meshes (panels kept for aesthetics, density=0 prevents phantom mass) -->
    <mesh name="Body_front" file="Body_front.stl"/>
    <mesh name="Board_PCB"  file="Board_PCB.stl"/>
    <mesh name="Shell_Side" file="Shell_Side.stl"/>

    <!-- Floor texture -->
    <texture name="grid" type="2d" builtin="checker"
             rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="4 4" reflectance="0.2"/>
  </asset>

  <!-- ============================================================ -->
  <!-- DEFAULTS                                                      -->
  <!-- kp=5.5, kd=0.25 matches Colab training_config defaults       -->
  <!-- ============================================================ -->
  <default>
    <!-- Top-level joint default - ensures damping applies everywhere -->
    <joint damping="0.25" armature="0.01" frictionloss="0.0"/>

    <!-- All joints: position-controlled servos -->
    <default class="leg_joint">
      <joint limited="true" range="-3.14 3.14"
             damping="0.25" armature="0.01" frictionloss="0.0"/>
    </default>

    <!-- Foot contact spheres -->
    <default class="foot_geom">
      <geom type="sphere" size="0.013"
            condim="6" conaffinity="1" contype="1" group="0"
            friction="1.5 0.005 0.0001"
            solref="0.02 1" solimp="0.9 0.95 0.001"/>
    </default>

    <!-- Collision capsules for leg links - invisible (alpha=0) -->
    <default class="collision_geom">
      <geom condim="3" conaffinity="1" contype="1" group="0"
            rgba="0 0 0 0"
            friction="0.8 0.005 0.0001"/>
    </default>

    <!-- Visual meshes: no collision, no mass contribution -->
    <default class="visual_geom">
      <geom conaffinity="0" contype="0" group="1" density="0"/>
    </default>

    <!-- Actuators: position control, kp=5.5 -->
    <default class="servo">
      <position kp="5.5" ctrlrange="-3.14 3.14" forcerange="-3.0 3.0"/>
    </default>
  </default>

  <!-- ============================================================ -->
  <!-- WORLDBODY                                                     -->
  <!-- ============================================================ -->
  <worldbody>

    <light name="spotlight" mode="targetbodycom" target="base_link"
           diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2"
           pos="0 -2 4" cutoff="60"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="10 10 0.1"
          material="grid" condim="3" conaffinity="1" contype="1"
          friction="1.5 0.005 0.0001"/>

    <!-- ============================================================ -->
    <!-- BASE / TORSO                                                  -->
    <!-- Spawn height 0.0804m: FK verified independently (hand calc +  -->
    <!-- MuJoCo mj_forward) with hip=0.994, knee=-1.767. Foot site     -->
    <!-- sits 0.06735m below base_link; + foot_radius 0.013m = 0.0804 -->
    <!-- ============================================================ -->
    <body name="base_link" pos="0 0 0.0804" quat="1 0 0 0">
      <freejoint name="root"/>

      <!-- Inertial from URDF: base_link + base_inertia combined mass -->

      <!-- Inertial: base_link + base_inertia + Body_front + Board_PCB + Shell_Side + lidar_link -->
      <!-- combined mass = 0.174884+0.0078552+0.0142616+0.0051929+0.108 = 0.30939 kg -->
      <!-- COM/inertia approximated at base_link's own values (dropped parts are small -->
      <!-- and roughly centered near base_link's origin; full parallel-axis correction -->
      <!-- is a refinement for later if mass distribution proves to matter further) -->
      <inertial mass="0.30939"
                pos="-0.008867 0.000396 -0.007154"
                fullinertia="0.00090939 0.00426716 0.00440707 1.27324e-7 1.05509e-9 -1.69927e-7"/>

      <site name="imu" size="0.01" pos="0 0 0"/>

      <!-- Torso collision: box approximation of body -->
      <geom name="base_collision" class="collision_geom"
            type="box" size="0.065 0.030 0.015"
            pos="-0.008 0 0" rgba="0 0 0 0"/>

      <!-- Visual meshes -->
      <!-- pos="0 0 0" because STL meshes are pre-offset in their own frame;  -->
      <!-- the URDF joint+visual offsets cancel each other out exactly.        -->
      <!-- density=0 set in visual_geom default class - no phantom mass        -->
      <geom name="base_visual"       class="visual_geom" type="mesh" mesh="base_link"  pos="0 0 0" rgba="0.15 0.15 0.15 1"/>
      <geom name="body_front_visual" class="visual_geom" type="mesh" mesh="Body_front" pos="0 0 0" rgba="1.0 0.85 0.0 1"/>
      <geom name="board_pcb_visual"  class="visual_geom" type="mesh" mesh="Board_PCB"  pos="0 0 0" rgba="0.15 0.15 0.15 1"/>
      <geom name="shell_side_visual" class="visual_geom" type="mesh" mesh="Shell_Side" pos="0 0 0" rgba="1.0 0.85 0.0 1"/>

      <!-- Tracking camera -->
      <camera name="tracking_cam" mode="trackcom"
              pos="0 -0.8 0.4" xyaxes="1 0 0 0 0.5 1"/>

      <!-- ========================================================= -->
      <!-- RIGHT FRONT LEG (rf)                                       -->
      <!-- Abduction joint at xyz="0.05 -0.0235 0.0" axis=x          -->
      <!-- ========================================================= -->
      <body name="rf1" pos="0.05 -0.0235 0.0">
        <joint name="base_rf1" class="leg_joint" axis="1 0 0" damping="0.25"/>
        <inertial mass="0.020769" pos="0.020109 -0.002332 0.006500"
                  fullinertia="2.494061e-6 3.735906e-6 3.222909e-6 7.662e-9 -0.014e-9 -33.565e-9"/>
        <geom name="rf1_visual"    class="visual_geom"    type="mesh"    mesh="rf1"  rgba="0.15 0.15 0.15 1"/>
        <geom name="rf1_collision" class="collision_geom" type="capsule" size="0.012" fromto="0 0 0  0.04 -0.002 0"/>

        <body name="rf2" pos="-4e-05 -0.0197 0.0">
          <joint name="rf1_rf2" class="leg_joint" axis="0 1 0" damping="0.25"/>
          <inertial mass="0.001906" pos="-0.003174 -0.000986 -0.017984"
                    fullinertia="0.462154e-6 0.481174e-6 26.893e-9 -3.117e-9 -17.662e-9 -79.269e-9"/>
          <geom name="rf2_visual"    class="visual_geom"    type="mesh"    mesh="rf2"  rgba="0.15 0.15 0.15 1"/>
          <geom name="rf2_collision" class="collision_geom" type="capsule" size="0.010" fromto="0 0 0  0 -0.005 -0.05"/>

          <body name="rf3" pos="0.0 -0.00475 -0.05">
            <joint name="rf2_rf3" class="leg_joint" axis="0 1 0" damping="0.25"/>
            <inertial mass="0.001144" pos="0.006211 -0.003456 -0.015014"
                      fullinertia="0.484471e-6 0.567615e-6 91.813e-9 2.101e-9 -5.008e-9 0.20057e-6"/>
            <geom name="rf3_visual"    class="visual_geom"    type="mesh"    mesh="rf3"  rgba="0.15 0.15 0.15 1"/>
            <geom name="rf3_collision" class="collision_geom" type="capsule" size="0.009" fromto="0 0 0  0 0 -0.05"/>

            <body name="rffoot" pos="0.0 0.0 -0.056">
            <!--  <inertial mass="0.001405" pos="-0.014 0.00025 0.002488"
                       fullinertia="41.995e-9 62.40e-9 29.798e-9 0 0 1.616e-9"/> -->
              <geom name="rffoot_geom"   class="foot_geom"   pos="0 0 0" rgba="0 0 0 0"/>
              <geom name="rffoot_visual" class="visual_geom" type="mesh" mesh="rffoot" rgba="0.1 0.1 0.1 1"/>
              <site name="rffoot_site"   size="0.01" pos="0 0 0"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ========================================================= -->
      <!-- LEFT FRONT LEG (lf)                                        -->
      <!-- Abduction joint at xyz="0.05 0.0235 0.0" axis=x           -->
      <!-- ========================================================= -->
      <body name="lf1" pos="0.05 0.0235 0.0">
        <joint name="base_lf1" class="leg_joint" axis="1 0 0" damping="0.25"/>
        <inertial mass="0.020769" pos="0.020109 0.002332 0.006500"
                  fullinertia="2.494061e-6 3.735906e-6 3.222909e-6 -7.662e-9 -0.014e-9 -33.565e-9"/>
        <geom name="lf1_visual"    class="visual_geom"    type="mesh"    mesh="lf1"  rgba="0.15 0.15 0.15 1"/>
        <geom name="lf1_collision" class="collision_geom" type="capsule" size="0.012" fromto="0 0 0  0.04 0.002 0"/>

        <body name="lf2" pos="-4e-05 0.0197 0.0">
          <joint name="lf1_lf2" class="leg_joint" axis="0 1 0" damping="0.25"/>
          <inertial mass="0.001906" pos="-0.003174 0.000986 -0.017984"
                    fullinertia="0.462154e-6 0.481174e-6 26.893e-9 3.117e-9 17.662e-9 -79.269e-9"/>
          <geom name="lf2_visual"    class="visual_geom"    type="mesh"    mesh="lf2"  rgba="0.15 0.15 0.15 1"/>
          <geom name="lf2_collision" class="collision_geom" type="capsule" size="0.010" fromto="0 0 0  0 0.005 -0.05"/>

          <body name="lf3" pos="0.0 0.00475 -0.05">
            <joint name="lf2_lf3" class="leg_joint" axis="0 1 0" damping="0.25"/>
            <inertial mass="0.001144" pos="0.006211 0.003456 -0.015014"
                      fullinertia="0.484471e-6 0.567615e-6 91.813e-9 -2.101e-9 5.008e-9 0.20057e-6"/>
            <geom name="lf3_visual"    class="visual_geom"    type="mesh"    mesh="lf3"  rgba="0.15 0.15 0.15 1"/>
            <geom name="lf3_collision" class="collision_geom" type="capsule" size="0.009" fromto="0 0 0  0 0 -0.05"/>

            <body name="lffoot" pos="0.0 0.0 -0.056">
            <!--   <inertial mass="0.001405" pos="-0.014 0.00025 0.002488"
                        fullinertia="41.995e-9 62.40e-9 29.798e-9 0 0 1.616e-9"/> -->
              <geom name="lffoot_geom"   class="foot_geom"   pos="0 0 0" rgba="0 0 0 0"/>
              <geom name="lffoot_visual" class="visual_geom" type="mesh" mesh="lffoot" rgba="0.1 0.1 0.1 1"/>
              <site name="lffoot_site"   size="0.01" pos="0 0 0"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ========================================================= -->
      <!-- RIGHT BACK LEG (rb)                                        -->
      <!-- Abduction joint at xyz="-0.066 -0.0235 0.0" axis=x        -->
      <!-- ========================================================= -->
      <body name="rb1" pos="-0.066 -0.0235 0.0">
        <joint name="base_rb1" class="leg_joint" axis="1 0 0" damping="0.25"/>
        <inertial mass="0.020769" pos="-0.020109 -0.002332 0.006500"
                  fullinertia="2.494061e-6 3.735906e-6 3.222909e-6 -7.662e-9 -0.014e-9 -33.565e-9"/>
        <geom name="rb1_visual"    class="visual_geom"    type="mesh"    mesh="rb1"  rgba="0.15 0.15 0.15 1"/>
        <geom name="rb1_collision" class="collision_geom" type="capsule" size="0.012" fromto="0 0 0  -0.04 -0.002 0"/>

        <body name="rb2" pos="-4e-05 -0.0197 0.0">
          <joint name="rb1_rb2" class="leg_joint" axis="0 1 0" damping="0.25"/>
          <inertial mass="0.001906" pos="-0.003174 -0.000986 -0.017984"
                    fullinertia="0.462154e-6 0.481174e-6 26.893e-9 -3.117e-9 -17.662e-9 -79.269e-9"/>
          <geom name="rb2_visual"    class="visual_geom"    type="mesh"    mesh="rb2"  rgba="0.15 0.15 0.15 1"/>
          <geom name="rb2_collision" class="collision_geom" type="capsule" size="0.010" fromto="0 0 0  0 -0.005 -0.05"/>

          <body name="rb3" pos="0.0 -0.00475 -0.05">
            <joint name="rb2_rb3" class="leg_joint" axis="0 1 0" damping="0.25"/>
            <inertial mass="0.001144" pos="0.006211 -0.003456 -0.015014"
                      fullinertia="0.484816e-6 0.567883e-6 91.777e-9 2.212e-9 -5.34e-9 0.200564e-6"/>
            <geom name="rb3_visual"    class="visual_geom"    type="mesh"    mesh="rb3"  rgba="0.15 0.15 0.15 1"/>
            <geom name="rb3_collision" class="collision_geom" type="capsule" size="0.009" fromto="0 0 0  0 0 -0.05"/>

            <body name="rbfoot" pos="0.0 0.0 -0.056">
           <!--    <inertial mass="0.001405" pos="-0.014 0.00025 0.002488"
                        fullinertia="41.995e-9 62.40e-9 29.798e-9 0 0 1.616e-9"/> -->
              <geom name="rbfoot_geom"   class="foot_geom"   pos="0 0 0" rgba="0 0 0 0"/>
              <geom name="rbfoot_visual" class="visual_geom" type="mesh" mesh="rbfoot" rgba="0.1 0.1 0.1 1"/>
              <site name="rbfoot_site"   size="0.01" pos="0 0 0"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ========================================================= -->
      <!-- LEFT BACK LEG (lb)                                         -->
      <!-- Abduction joint at xyz="-0.066 0.0235 0.0" axis=x         -->
      <!-- ========================================================= -->
      <body name="lb1" pos="-0.066 0.0235 0.0">
        <joint name="base_lb1" class="leg_joint" axis="1 0 0" damping="0.25"/>
        <inertial mass="0.020769" pos="-0.020109 0.002332 0.006500"
                  fullinertia="2.494061e-6 3.735906e-6 3.222909e-6 7.662e-9 -0.014e-9 -33.565e-9"/>
        <geom name="lb1_visual"    class="visual_geom"    type="mesh"    mesh="lb1"  rgba="0.15 0.15 0.15 1"/>
        <geom name="lb1_collision" class="collision_geom" type="capsule" size="0.012" fromto="0 0 0  -0.04 0.002 0"/>

        <body name="lb2" pos="-4e-05 0.0197 0.0">
          <joint name="lb1_lb2" class="leg_joint" axis="0 1 0" damping="0.25"/>
          <inertial mass="0.001906" pos="-0.003174 0.000986 -0.017984"
                    fullinertia="0.462154e-6 0.481174e-6 26.893e-9 3.117e-9 17.662e-9 -79.269e-9"/>
          <geom name="lb2_visual"    class="visual_geom"    type="mesh"    mesh="lb2"  rgba="0.15 0.15 0.15 1"/>
          <geom name="lb2_collision" class="collision_geom" type="capsule" size="0.010" fromto="0 0 0  0 0.005 -0.05"/>

          <body name="lb3" pos="0.0 0.00475 -0.05">
            <joint name="lb2_lb3" class="leg_joint" axis="0 1 0" damping="0.25"/>
            <inertial mass="0.001144" pos="0.006211 0.003456 -0.015014"
                      fullinertia="0.484471e-6 0.567615e-6 91.813e-9 -2.101e-9 5.008e-9 0.20057e-6"/>
            <geom name="lb3_visual"    class="visual_geom"    type="mesh"    mesh="lb3"  rgba="0.15 0.15 0.15 1"/>
            <geom name="lb3_collision" class="collision_geom" type="capsule" size="0.009" fromto="0 0 0  0 0 -0.05"/>

            <body name="lbfoot" pos="0.0 0.0 -0.056">
           <!--    <inertial mass="0.001405" pos="-0.014 0.00025 0.002488"
                        fullinertia="41.995e-9 62.40e-9 29.798e-9 0 0 1.616e-9"/> -->
              <geom name="lbfoot_geom"   class="foot_geom"   pos="0 0 0" rgba="0 0 0 0"/>
              <geom name="lbfoot_visual" class="visual_geom" type="mesh" mesh="lbfoot" rgba="0.1 0.1 0.1 1"/>
              <site name="lbfoot_site"   size="0.01" pos="0 0 0"/>
            </body>
          </body>
        </body>
      </body>

    </body><!-- end base_link -->
  </worldbody>

  <!-- ============================================================ -->
  <!-- KEYFRAMES                                                     -->
  <!-- "home" = default standing pose                                -->
  <!-- qpos layout: 7 free joint (pos+quat) + 12 joint angles       -->
  <!-- Joint order: RF(abd,hip,knee) LF(abd,hip,knee)               -->
  <!--              RB(abd,hip,knee) LB(abd,hip,knee)               -->
  <!-- Values from URDF: startup_abduction=0, hip=0.994, knee=-1.767-->
  <!-- Spawn height 0.0804m verified by independent FK (hand calc + -->
  <!-- MuJoCo mj_forward, agree to 5 decimal places): foot site sits -->
  <!-- 0.06735m below base_link at these angles. foot_radius=0.013m, -->
  <!-- so base_z = 0.06735 + 0.013 = 0.0804m puts feet exactly on    -->
  <!-- floor at spawn (previous 0.057m buried feet 1.5-2.3cm into    -->
  <!-- the ground at every episode reset - confirmed via mj_forward  -->
  <!-- contact penetration check)                                    -->
  <!-- ============================================================ -->
  <keyframe>
    <key name="home"
         qpos="0 0 0.0804 1 0 0 0
               0.0  0.994 -1.767
               0.0  0.994 -1.767
               0.0  0.994 -1.767
               0.0  0.994 -1.767"/>
  </keyframe>

  <!-- ============================================================ -->
  <!-- ACTUATORS                                                     -->
  <!-- Order: RF, LF, RB, LB — each: abduction, hip, knee          -->
  <!-- Must match default_pose order in Colab                       -->
  <!-- ============================================================ -->
  <actuator>
    <!-- Right Front -->
    <position name="act_base_rf1" class="servo" joint="base_rf1"/>
    <position name="act_rf1_rf2"  class="servo" joint="rf1_rf2"/>
    <position name="act_rf2_rf3"  class="servo" joint="rf2_rf3"/>
    <!-- Left Front -->
    <position name="act_base_lf1" class="servo" joint="base_lf1"/>
    <position name="act_lf1_lf2"  class="servo" joint="lf1_lf2"/>
    <position name="act_lf2_lf3"  class="servo" joint="lf2_lf3"/>
    <!-- Right Back -->
    <position name="act_base_rb1" class="servo" joint="base_rb1"/>
    <position name="act_rb1_rb2"  class="servo" joint="rb1_rb2"/>
    <position name="act_rb2_rb3"  class="servo" joint="rb2_rb3"/>
    <!-- Left Back -->
    <position name="act_base_lb1" class="servo" joint="base_lb1"/>
    <position name="act_lb1_lb2"  class="servo" joint="lb1_lb2"/>
    <position name="act_lb2_lb3"  class="servo" joint="lb2_lb3"/>
  </actuator>

  <!-- ============================================================ -->
  <!-- SENSORS                                                       -->
  <!-- IMU at body origin                                            -->
  <!-- ============================================================ -->
  <sensor>
    <gyro        name="gyro"        site="imu"/>
    <accelerometer name="accelerometer" site="imu"/>
    <framequat   name="body_quat"   objtype="site" objname="imu"/>
  </sensor>

</mujoco>
